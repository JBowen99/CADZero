# OpenRouter API key — OPTIONAL in the packaged desktop app.
# Get one at https://openrouter.ai/keys.
#
# In the packaged Electron app, the key is set via the Settings dialog and
# stored encrypted with your OS keychain (Electron safeStorage).
#
# This env var is only used as a read-only fallback when running the backend
# standalone (pnpm dev:server). It is ignored by the desktop app.
OPENROUTER_API_KEY=

# To test the in-app Settings/provider dialog flow with the standalone server,
# set CADZ_DEV_CREDENTIALS=1 so keys entered in the UI are persisted to
# ~/.cadzero/dev-credentials.json (plaintext, for dev only).
# CADZ_DEV_CREDENTIALS=1

# Fallback model id (used only if server/models.config.json cannot be loaded).
# The list of selectable models lives in server/models.config.json and is
# validated against the OpenRouter /api/v1/models endpoint at runtime.
OPENROUTER_MODEL=openai/gpt-4o-mini

# Port the AI backend listens on
PORT=8787

# Origin allowed by CORS (the frontend dev server). Use "*" to allow any origin.
ALLOWED_ORIGIN=http://localhost:5173
