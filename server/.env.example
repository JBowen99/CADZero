# OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=replace-me

# Any model id from https://openrouter.ai/models (OpenAI-compatible via OpenRouter)
OPENROUTER_MODEL=openai/gpt-4o-mini

# Port the AI backend listens on
PORT=8787

# Origin allowed by CORS (the frontend dev server). Use "*" to allow any origin.
ALLOWED_ORIGIN=http://localhost:5173
